# Copy this file to .env and adjust values for your machine.

# launchd label. Keep it unique per user/project.
LABEL=com.activation-timer.ai-window

# Local time schedule for macOS launchd.
# Use comma-separated 24-hour values and a shared minute.
SCHEDULE_HOURS=7,12,17,22
SCHEDULE_MINUTE=0

# Which tools to activate: all, claude, or codex.
ACTIVATION_TOOL=all

# The low-cost prompt sent during activation.
ACTIVATION_PROMPT="Reply exactly READY. Do not inspect files, run tools, or modify anything."

# Per-tool timeout in seconds.
TIMEOUT_SECONDS=120

# Set to 0 if you only want activation logs and per-run usage, not quota snapshots.
ENABLE_STATUS_SNAPSHOTS=1

# Check quota before sending a prompt. If a known five-hour or weekly quota is
# exhausted, the run is skipped and recorded instead of calling the CLI.
ENABLE_QUOTA_PREFLIGHT=1

# What to do when quota cannot be checked: allow or skip.
QUOTA_PREFLIGHT_ON_UNKNOWN=allow

# Skip when remaining quota is at or below this percentage.
QUOTA_EXHAUSTED_THRESHOLD_PERCENT=0

# Override binary paths only when auto-discovery fails.
# CLAUDE_BIN="${HOME}/.local/bin/claude"
# CODEX_BIN=/opt/homebrew/bin/codex
# JQ_BIN=/usr/bin/jq
# NODE_BIN=/opt/homebrew/bin/node
# OMC_BIN=/opt/homebrew/bin/omc

# PATH used by launchd and the runner.
# PATH_VALUE="${HOME}/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
